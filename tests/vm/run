#!/bin/sh
# This file is part of KASLD - https://github.com/bcoles/kasld
#
# tests/vm/run — reproducible cross-architecture LIVE soundness check.
#
# For each architecture, this boots a real, publicly-fetchable kernel under
# qemu-system, captures the kernel's ground-truth text base, runs the
# cross-built kasld against the running kernel, and verifies the soundness
# invariant the whole tool rests on:
#
#     truth ∈ [virt_image_base_min, virt_image_base_max]
#
# Unlike tests/replay (offline, over captured fixtures), this exercises kasld
# end to end against a live kernel — the same check a user can run on their own
# machine with extra/collect + extra/validate-bundle, generalised across arches.
#
# Prerequisites:
#   - `make cross` already run (build/<triple>/kasld + components), with the
#     same cross toolchains on PATH (used here to build the tiny init).
#   - qemu-system-<arch> on PATH (the host's qemu packages, e.g. Debian/Ubuntu
#     qemu-system-x86 / -arm / -misc). Guest kernels are fetched from Alpine.
#   - curl, cpio, gzip.
#
# Usage:
#   tests/vm/run                 # every supported arch, default profile
#   tests/vm/run <arch>          # one arch, default profile
#   tests/vm/run <arch> <mode>   # mode: default | hidden | hardened | nokaslr
#   tests/vm/run all <mode>      # every arch in a given mode
#   tests/vm/run table           # render the results matrix (markdown) from the
#                                # boot logs, followed by the speculative-
#                                # narrowing table
#   tests/vm/run spec-table      # render only the speculative-narrowing table
#                                # (cells where the likely window beats guaranteed)
#
# Modes:
#   default   root, kptr_restrict=0 — kasld may read kallsyms (the easy case)
#   hidden    root, kptr_restrict=2 — pin must come from inference
#   hardened  uid 1000 + kptr=2/dmesg_restrict=1/perf=3 — unprivileged floor
#   nokaslr   boot with `nokaslr` — verifies the KASLR-disabled pin
#
# Env overrides:
#   QEMU_DIR        directory holding qemu-system-* (default: search PATH)
#   ALPINE_VER      Alpine release for netboot kernels (default: 3.21)
#   ALPINE_MIRROR   mirror base URL
#   BUILD_DIR       kasld build root (default: ./build)
#   LOONGARCH_BIOS  path to edk2 loongarch firmware (loongarch64 needs UEFI)
#   TIMEOUT         per-boot timeout seconds (default: 240)
# ---
# <bcoles@gmail.com>
set -u

HERE=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
ROOT=$(CDPATH='' cd -- "$HERE/../.." && pwd)
BUILD_DIR=${BUILD_DIR:-$ROOT/build}
QEMU_DIR=${QEMU_DIR:-}
ALPINE_VER=${ALPINE_VER:-3.21}
ALPINE_MIRROR=${ALPINE_MIRROR:-https://dl-cdn.alpinelinux.org/alpine}
TIMEOUT=${TIMEOUT:-600}
CACHE=$HERE/.cache

# name | alpine-arch | flavor | build-prefix | qemu-suffix | machine | console
#   flavor: a netboot kernel name (virt/lts) or "apk" (extract vmlinuz from the
#   linux-lts apk — for ports with no netboot image, e.g. riscv64/loongarch64).
TABLE='
x86_64      | x86_64      | virt | x86_64       | x86_64      | -M q35 -cpu max        | ttyS0
i686        | x86         | lts  | i686         | i386        | -M pc -cpu max         | ttyS0
aarch64     | aarch64     | virt | aarch64      | aarch64     | -M virt -cpu max       | ttyAMA0
armv7       | armv7       | lts  | armv7        | arm         | -M virt -cpu max       | ttyAMA0
riscv64     | riscv64     | apk  | riscv64      | riscv64     | -M virt                | ttyS0
loongarch64 | loongarch64 | apk  | loongarch64  | loongarch64 | -M virt                | ttyS0
ppc64le     | ppc64le     | lts  | powerpc64le  | ppc64       | -M pseries -cpu power9 | hvc0
s390x       | s390x       | lts  | s390x        | s390x       | -M s390-ccw-virtio     | ttysclp0
mips        | -           | local| mips         | mips        | -M malta               | ttyS0
mipsel      | -           | local| mipsel       | mipsel      | -M malta               | ttyS0
riscv32     | -           | local| riscv32      | riscv32     | -M virt                | ttyS0
ppc32       | -           | local| powerpc      | ppc         | -M g3beige             | ttyS0
armeb       | -           | local| armeb        | arm         | -M virt                | ttyAMA0
x86_64-vanilla | -        | local| x86_64       | x86_64      | -M q35 -cpu max        | ttyS0
'

trim() { echo "$1" | xargs; }

# True if ELF $1 has no dynamic interpreter (static / static-pie) — the minimal
# initramfs carries no loader or shared libs, so only static binaries run.
is_static() {
  if command -v readelf >/dev/null 2>&1; then
    ! readelf -l "$1" 2>/dev/null | grep -q 'INTERP'
  else
    ! file -L "$1" 2>/dev/null | grep -q 'dynamically linked'
  fi
}

# Echo "<build-dir> <cc>" for build-prefix $1: the first build/<prefix>-*/ whose
# kasld is present AND static (the host gnu build is dynamic; `make cross` musl
# builds are static-pie) AND whose <triple>-gcc is on PATH (the toolchain that
# built it, reused here to cross-compile init.c). Empty if none.
resolve_target() {
  for d in "$BUILD_DIR/$1"-*; do
    [ -x "$d/kasld" ] || continue
    [ -d "$d/components" ] || continue
    is_static "$d/kasld" || continue
    t=$(basename "$d")
    if command -v "$t-gcc" >/dev/null 2>&1; then echo "$d $t-gcc"; return; fi
  done
}

# qemu binary for suffix $1: prefer QEMU_DIR, else fall back to PATH. Empty if
# neither has it. The preference (not exclusive) lets one run mix a locally built
# qemu (e.g. qemu-system-ppc) with the system qemu for the other arches.
resolve_qemu() {
  if [ -n "$QEMU_DIR" ] && [ -x "$QEMU_DIR/qemu-system-$1" ]; then
    echo "$QEMU_DIR/qemu-system-$1"
  else
    command -v "qemu-system-$1" 2>/dev/null
  fi
}

# Fetch (and cache) the kernel for one arch. Args: name alpine-arch flavor dest
fetch_kernel() {
  _name=$1 _aarch=$2 _flavor=$3 _dest=$4
  [ -f "$_dest" ] && return 0
  mkdir -p "$(dirname "$_dest")"
  if [ "$_flavor" = local ]; then
    # Gap arch with no Alpine port: the kernel is supplied locally, not fetched.
    # Produce one with tests/vm/build-kernel, or drop a stock kernel (e.g. from a
    # Debian qemu image) at this path. Absent -> skip, never a false download.
    echo "  !! no kernel at $_dest — build it (tests/vm/build-kernel $_name) or"
    echo "     copy a stock kernel for this arch there, then re-run"
    return 1
  elif [ "$_flavor" = apk ]; then
    _repo="$ALPINE_MIRROR/edge/main/$_aarch"
    _apk=$(curl -fsSL "$_repo/" | grep -oE 'linux-lts-[0-9][^"<]*\.apk' | sort -V | tail -1)
    [ -n "$_apk" ] || { echo "  !! no linux-lts apk for $_aarch"; return 1; }
    _tmp=$(mktemp -d)
    curl -fsSL -o "$_tmp/k.apk" "$_repo/$_apk" || { rm -rf "$_tmp"; return 1; }
    # An apk is concatenated gzip streams; -i reads across the control segment.
    (cd "$_tmp" && tar -xzif k.apk boot/vmlinuz-lts 2>/dev/null)
    [ -f "$_tmp/boot/vmlinuz-lts" ] || { echo "  !! no vmlinuz in $_apk"; rm -rf "$_tmp"; return 1; }
    # Some ports ship the image gzip-compressed; qemu -kernel wants it raw.
    if gzip -t "$_tmp/boot/vmlinuz-lts" 2>/dev/null; then
      gunzip -c "$_tmp/boot/vmlinuz-lts" >"$_dest"
    else
      cp "$_tmp/boot/vmlinuz-lts" "$_dest"
    fi
    rm -rf "$_tmp"
  else
    _url="$ALPINE_MIRROR/v$ALPINE_VER/releases/$_aarch/netboot/vmlinuz-$_flavor"
    echo "  [*] fetching $_url"
    curl -fsSL -o "$_dest" "$_url" || { echo "  !! kernel download failed"; rm -f "$_dest"; return 1; }
  fi
}

# --- soundness verdict from a boot log (adapted from the matrix extractor) ---
norm() { v=$(printf '%s' "$1" | sed 's/^0x//' | tr 'A-F' 'a-f'); [ -n "$v" ] || return 0; printf '%016s' "$v" | tr ' ' 0; }
hexle() { [ "$1" = "$2" ] && return 0; [ "$(printf '%s\n%s\n' "$1" "$2" | LC_ALL=C sort | head -1)" = "$1" ]; }

# verdict <log>: prints "PASS|FAIL|N/A  <detail>" and returns 0 only on PASS/NA.
verdict() {
  _log=$1
  grep -aq 'KASLD VM DONE' "$_log" || { echo "INCOMPLETE  (boot did not finish; see $_log)"; return 1; }
  _truth=$(awk '/ _text$/{print $1; exit}' "$_log")
  [ -n "$_truth" ] || _truth=$(awk '/ _stext$/{print $1; exit}' "$_log")
  _min=$(grep -am1 -oE '"virt_image_base_min": *"0x[0-9a-fA-F]+"' "$_log" | grep -oE '0x[0-9a-fA-F]+')
  _max=$(grep -am1 -oE '"virt_image_base_max": *"0x[0-9a-fA-F]+"' "$_log" | grep -oE '0x[0-9a-fA-F]+')
  _disabled=$(grep -am1 -oE '"disabled": *(true|false)' "$_log" | awk '{print $2}')
  _t=$(norm "$_truth"); _lo=$(norm "$_min"); _hi=$(norm "$_max")
  if [ -z "$_t" ] || [ -z "$_lo" ] || [ -z "$_hi" ]; then
    echo "N/A   truth=${_truth:--} window=[${_min:--},${_max:--}] disabled=${_disabled:-?}"
    return 0
  fi
  if hexle "$_lo" "$_t" && hexle "$_t" "$_hi"; then
    _rec=N; [ "$_lo" = "$_hi" ] && _rec=Y
    echo "PASS  truth=$_truth ∈ [$_min,$_max] recovered=$_rec"
    return 0
  fi
  echo "FAIL  truth=$_truth OUTSIDE [$_min,$_max] — soundness violation"
  return 1
}

# Build + boot one arch in one mode. Returns the verdict's status.
run_one() {
  name=$1 mode=$2
  row=$(echo "$TABLE" | grep -E "^[[:space:]]*${name}[[:space:]]*\|")
  [ -n "$row" ] || { echo "$name: unknown arch"; return 2; }
  IFS='|' read -r _ aarch flavor prefix qsuf machine console <<EOF
$row
EOF
  aarch=$(trim "$aarch"); flavor=$(trim "$flavor"); prefix=$(trim "$prefix")
  qsuf=$(trim "$qsuf"); machine=$(trim "$machine"); console=$(trim "$console")

  # Guest RAM. Default 1 GiB; the qemu malta board (mips) caps at 256 MiB.
  mem=1024; case "$name" in mips | mipsel | mips64 | mips64el) mem=256 ;; esac

  echo "=================== $name ($mode) ==================="
  tc=$(resolve_target "$prefix")
  [ -n "$tc" ] || { echo "  SKIP  no build/$prefix-*/kasld with toolchain on PATH (run make cross)"; return 3; }
  bdir=${tc% *}; cc=${tc#* }
  qemu=$(resolve_qemu "$qsuf")
  [ -n "$qemu" ] || { echo "  SKIP  qemu-system-$qsuf not found"; return 3; }

  work=$HERE/$name
  mkdir -p "$work"
  fetch_kernel "$name" "$aarch" "$flavor" "$CACHE/$name-vmlinuz" || { echo "  SKIP  no kernel"; return 3; }

  "$cc" -O2 -static -o "$work/init.bin" "$HERE/init.c" || { echo "  !! init build failed ($cc)"; return 2; }

  rm -rf "$work/root"
  mkdir -p "$work/root/proc" "$work/root/sys" "$work/root/dev" "$work/root/tmp" "$work/root/components"
  cp "$work/init.bin" "$work/root/init"
  cp "$bdir/kasld" "$work/root/kasld"
  cp "$CACHE/$name-vmlinuz" "$work/root/kernel-image"
  cp "$bdir"/components/* "$work/root/components/" 2>/dev/null || true
  chmod +x "$work/root/init" "$work/root/kasld" "$work/root/components/"* 2>/dev/null || true
  (cd "$work/root" && find . -print0 | cpio --null -o --format=newc 2>/dev/null | gzip -9 >"$work/initramfs.cpio.gz")

  # Some boards need firmware the qemu binary does not bundle. Discover it next to
  # the resolved qemu (a from-source build keeps it in pc-bios/), in the usual
  # system share dirs, or in the distro's cross opensbi package — overridable per
  # arch. The firmware must match the qemu that loads it.
  #   loongarch64 — boots via UEFI; its kernel is an EFI PE needing an edk2 image.
  #   riscv32     — qemu ships only the riscv64 OpenSBI; supply the 32-bit one.
  bios=""
  if [ "$name" = loongarch64 ]; then
    fw=${LOONGARCH_BIOS:-}
    if [ -z "$fw" ]; then
      for c in "$(dirname "$qemu")/pc-bios/edk2-loongarch64-code.fd" \
               /usr/share/qemu/edk2-loongarch64-code.fd \
               /usr/share/edk2/loongarch64/QEMU_EFI.fd; do
        [ -f "$c" ] && { fw=$c; break; }
      done
    fi
    [ -n "$fw" ] && bios="-bios $fw"
  elif [ "$name" = riscv32 ]; then
    fw=${RISCV32_BIOS:-}
    if [ -z "$fw" ]; then
      for c in "$(dirname "$qemu")/pc-bios/opensbi-riscv32-generic-fw_dynamic.bin" \
               /usr/share/qemu/opensbi-riscv32-generic-fw_dynamic.bin \
               /usr/lib/riscv32-linux-gnu/opensbi/generic/fw_dynamic.bin; do
        [ -f "$c" ] && { fw=$c; break; }
      done
    fi
    [ -n "$fw" ] && bios="-bios $fw"
  fi

  # Opportunistic hardware acceleration: when the guest matches the host arch and
  # /dev/kvm is usable, KVM makes the boot near-native and immune to host load.
  # Foreign arches stay on TCG emulation (slow but correct). KVM is happy with
  # the table's `-cpu max`.
  accel=""
  if [ -w /dev/kvm ]; then
    case "$qsuf:$(uname -m)" in
      x86_64:x86_64 | i386:x86_64 | i386:i686 | aarch64:aarch64) accel="-enable-kvm" ;;
    esac
  fi

  append="console=$console panic=-1 quiet"
  case "$mode" in
    default)  ;;
    hidden)   append="$append hidekptr" ;;
    hardened) append="$append hardened" ;;
    stock)    append="$append stock" ;;
    nokaslr)  append="$append nokaslr" ;;
    *) echo "  unknown mode: $mode"; return 2 ;;
  esac

  log="$work/boot-$mode.log"
  echo "  [*] booting $qemu ($machine) -> $log"
  # shellcheck disable=SC2086
  timeout "$TIMEOUT" $qemu $machine $accel -smp 1 -m "$mem" $bios \
    -kernel "$CACHE/$name-vmlinuz" -initrd "$work/initramfs.cpio.gz" \
    -nographic -no-reboot -append "$append" >"$log" 2>&1 || true
  # Strip CR and NUL bytes: early console output can contain binary noise that
  # makes grep treat the log as binary and skip matches.
  tr -d '\r\000' <"$log" >"$log.clean" && mv "$log.clean" "$log"

  printf '  %-11s ' "$name"
  verdict "$log"
}

# Virtual-side KASLR residual entropy from a boot log's -j JSON, or empty.
# entropy_bits appears in both the virt and phys kaslr sub-objects; take the
# virt one (before the physical/memory markers).
bits_of() {
  awk '/"kaslr": *\{/{ink=1}
       ink && /"(physical|inferred_physical|memory_kaslr)":/{ink=0}
       ink && /"entropy_bits":/{gsub(/[^0-9]/,""); print; exit}' "$1"
}

# Format an entropy-bit count as a residual cell: 0 -> exact, 1 -> "1 bit",
# n -> "n bits", empty -> em dash.
fmt_bits() {
  case "$1" in
    0)      echo exact ;;
    1)      echo '1 bit' ;;
    '' | —) echo '—' ;;
    *)      echo "$1 bits" ;;
  esac
}

# Virtual-side speculative-narrowing fields from a boot log, or nothing when the
# likely window does not diverge from guaranteed. The engine emits the `likely`
# object only when it is strictly tighter than guaranteed, so its presence IS the
# divergence. `via`/`method` are attributed to the `groups` entry whose consensus
# edge (lo/hi/consensus) coincides with a likely-window edge — the leak or timing
# signal that pinned the speculative base; for coupled arches with no text leak
# this resolves to the directmap/dram base whose image-size ceiling narrowed it.
# Prints one pipe-delimited record: gbits|lbits|lmin|lmax|method|via
likely_of() {
  awk '
    function val(s){ sub(/^[^:]*:[ \t]*/,"",s); gsub(/[",]/,"",s);
                     gsub(/^[ \t]+|[ \t]+$/,"",s); return s }
    function orig(s){ sub(/^[^:]*:[ \t]*\[/,"",s); sub(/\].*/,"",s);
                      gsub(/[" ]/,"",s); gsub(/,/," + ",s); return s }
    function match_edge(target,   i){
      for(i=1;i<=gi;i++) if(glo[i]==target||ghi[i]==target||gcons[i]==target){
        method=gcm[i]; via=gorg[i]; return 1 } return 0 }
    /"kaslr":[ \t]*\{/{ ink=1 }
    ink && /"inferred":[ \t]*\{/{ blk="inf" }
    ink && /"likely":[ \t]*\{/{ blk="lik" }
    ink && /"inferred_physical":/{ blk=""; ink=0 }
    blk=="inf" && /"entropy_bits":/{ gbits=val($0) }
    blk=="lik" && /"range_min":/{ lmin=val($0) }
    blk=="lik" && /"range_max":/{ lmax=val($0) }
    blk=="lik" && /"entropy_bits":/{ lbits=val($0); blk="" }
    /"likely_physical":[ \t]*\{/{ lpk=1 }
    lpk && /"range_min":/{ lpmin=val($0) }
    lpk && /"range_max":/{ lpmax=val($0); lpk=0 }
    /"groups":[ \t]*\[/{ ing=1 }
    ing && /"type":/{ gi++; gorg[gi]="" }
    ing && gi>0 && /"consensus":/{ gcons[gi]=val($0) }
    ing && gi>0 && /"consensus_method":/{ gcm[gi]=val($0) }
    ing && gi>0 && /"lo":/{ glo[gi]=val($0) }
    ing && gi>0 && /"hi":/{ ghi[gi]=val($0) }
    ing && gi>0 && /"origins":/{ if(gorg[gi]=="") gorg[gi]=orig($0) }
    END{
      if(lmax==""){ exit }        # no likely block -> no divergence
      method="?"; via="?"
      if(!match_edge(lmax) && !match_edge(lmin) && lpmax!="")
        if(!match_edge(lpmax)) match_edge(lpmin)
      printf "%s|%s|%s|%s|%s|%s\n", gbits, lbits, lmin, lmax, method, via
    }' "$1"
}

# Render the speculative-narrowing table (markdown): the cells where the likely
# best-guess window is tighter than the guaranteed one, the signal that drove it,
# and whether that guess contained the truth. Unlike the matrix this is NOT gated
# — a likely miss is disclosed here, never withheld, because the soundness gate is
# on the guaranteed matrix. Emits nothing but a note when no cell diverges.
cmd_spec_table() {
  nl='
'
  body=
  for a in $arches; do
    arch_disp=${a%-vanilla}
    for scen in default hidden hardened; do
      log="$HERE/$a/boot-$scen.log"
      [ -f "$log" ] || continue
      grep -aq 'KASLD VM DONE' "$log" || continue
      row=$(likely_of "$log"); [ -n "$row" ] || continue   # likely == guaranteed
      IFS='|' read -r gbits lbits lmin lmax method via <<EOF
$row
EOF
      truth=$(awk '/ _text$/{print $1; exit}' "$log")
      [ -n "$truth" ] || truth=$(awk '/ _stext$/{print $1; exit}' "$log")
      t=$(norm "$truth"); lo=$(norm "$lmin"); hi=$(norm "$lmax")
      hit='—'
      if [ -n "$t" ] && [ -n "$lo" ] && [ -n "$hi" ]; then
        if hexle "$lo" "$t" && hexle "$t" "$hi"; then hit=yes; else hit='**NO**'; fi
      fi
      flavor=$(printf '%s' "$TABLE" | awk -F'|' -v a="$a" 'NF>1{gsub(/ /,"",$1); if ($1==a) {gsub(/ /,"",$3); print $3; exit}}')
      src=alpine; [ "$flavor" = local ] && src=mainline
      body="${body}| $arch_disp | $src | $scen | $(fmt_bits "$gbits") | $(fmt_bits "$lbits") | \`$via\` | $method | $hit |${nl}"
    done
  done

  if [ -z "$body" ]; then
    printf 'No speculative narrowing: the likely window equals guaranteed on every cell.\n'
    return 0
  fi
  printf '| arch | source | scenario | guaranteed | likely | via | method | truth ∈ likely |\n'
  printf '|------|--------|----------|------------|--------|-----|--------|:---:|\n'
  printf '%s' "$body"
  # shellcheck disable=SC2016  # backticks are literal markdown, not a subshell
  printf '\n`via`/`method` = the sub-floor signal that narrowed the base past the sound floor; `truth ∈ likely` = whether that best-guess window still contained the real base. A `**NO**` is disclosed, not withheld — the soundness gate is on the guaranteed matrix above, which contains the truth regardless. Every other KASLR-on cell: likely equals guaranteed.\n'
}

# Render the results matrix (markdown) from the boot logs left by previous runs.
# One row per existing boot-<scenario>.log. Every column describes the GUARANTEED
# window — the one resolved at the sound floor, which must contain the truth.
# `residual` is the only result column: how much of the base KASLD could not pin
# down (i.e. how effectively KASLR was defeated).
cmd_table() {
  nl='
'
  bad=    # cells that are NOT verified sound (gate); refusing to emit if any
  body=
  for a in $arches; do
    # Matrix label is the real architecture. A reference kernel staged under a
    # "<arch>-vanilla" name (e.g. x86_64-vanilla) is the SAME arch as its distro
    # sibling — the `source` column carries the distro-vs-mainline split — so
    # strip the suffix rather than print a non-arch name.
    arch_disp=${a%-vanilla}
    for scen in default hidden hardened nokaslr; do
      log="$HERE/$a/boot-$scen.log"
      [ -f "$log" ] || continue   # arch not built (no kernel) — simply omitted
      rel=$(grep -am1 'Linux version' "$log" | sed -E 's/.*Linux version ([^ ]+).*/\1/')
      [ -n "$rel" ] || rel='?'
      if ! grep -aq 'KASLD VM DONE' "$log"; then
        bad="${bad}  $a/$scen: boot did not finish${nl}"; continue
      fi
      truth=$(awk '/ _text$/{print $1; exit}' "$log")
      [ -n "$truth" ] || truth=$(awk '/ _stext$/{print $1; exit}' "$log")
      min=$(grep -am1 -oE '"virt_image_base_min": *"0x[0-9a-fA-F]+"' "$log" | grep -oE '0x[0-9a-fA-F]+')
      max=$(grep -am1 -oE '"virt_image_base_max": *"0x[0-9a-fA-F]+"' "$log" | grep -oE '0x[0-9a-fA-F]+')
      disabled=$(grep -am1 -oE '"disabled": *(true|false)' "$log" | awk '{print $2}')
      bits=$(bits_of "$log"); [ -n "$bits" ] || bits='—'
      t=$(norm "$truth"); lo=$(norm "$min"); hi=$(norm "$max")
      if [ -z "$t" ] || [ -z "$lo" ] || [ -z "$hi" ]; then
        bad="${bad}  $a/$scen: could not extract truth/window${nl}"; continue
      fi
      # SOUNDNESS GATE: the guaranteed window MUST contain the truth. A cell that
      # fails this is a bug, never something to publish — so it is collected as a
      # violation and the whole table is withheld (see below), not printed.
      if hexle "$lo" "$t" && hexle "$t" "$hi"; then :; else
        bad="${bad}  $a/$scen: truth $truth OUTSIDE [$min,$max] — soundness violation${nl}"
        continue
      fi
      kas=on; [ "$disabled" = true ] && kas=off
      # Kernel source: a vanilla kernel.org build (TABLE flavor "local") vs an
      # Alpine distro kernel.
      flavor=$(printf '%s' "$TABLE" | awk -F'|' -v a="$a" 'NF>1{gsub(/ /,"",$1); if ($1==a) {gsub(/ /,"",$3); print $3; exit}}')
      src=alpine; [ "$flavor" = local ] && src=mainline
      # Residual: how much KASLR entropy KASLD could NOT strip from the base.
      #   exact    : base recovered — KASLR defeated. A byte-exact pin and a
      #              sub-slot window (below KASLR granularity) are the same
      #              outcome here: the randomized slot is known.
      #   <n> bits : KASLR-randomized, n bits of the slot still unknown.
      #   —        : KASLR off — no randomization to defeat.
      if [ "$kas" = off ]; then
        residual='—'
      elif [ "$lo" = "$hi" ] || [ "$bits" = 0 ] || [ "$bits" = '—' ]; then
        residual=exact
      elif [ "$bits" = 1 ]; then
        residual='1 bit'
      else
        residual="$bits bits"
      fi
      # nokaslr is a control (KASLR forced off → always "—"); it carries no
      # per-arch signal, so it is gate-checked above like every other cell but
      # kept out of the rendered matrix.
      [ "$scen" = nokaslr ] || body="${body}| $arch_disp | $rel | $src | $scen | $kas | $residual |${nl}"
    done
  done

  # Soundness is a GATE, not a column: if any cell is not verified sound, refuse
  # to emit the matrix (and report which cells), so an unsound or unverifiable
  # result can never be published.
  if [ -n "$bad" ]; then
    printf 'SOUNDNESS GATE FAILED — refusing to emit the matrix. Cells not verified sound:\n%s' "$bad" >&2
    return 1
  fi

  printf '| arch | release | source | scenario | KASLR | residual |\n'
  printf '|------|---------|--------|----------|-------|----------|\n'
  printf '%s' "$body"
  # shellcheck disable=SC2016  # backticks are literal markdown, not a subshell
  printf '\nEvery cell is sound: the true base lies inside the guaranteed window. `source` = `alpine` (distro kernel) or `mainline` (vanilla kernel.org build). `residual` = how much KASLR entropy KASLD could not strip from the base: `exact` = base recovered, KASLR defeated (a byte-exact pin and a below-granularity sub-slot window are the same outcome — the randomized slot is known); `<n> bits` = KASLR-randomized, n bits of the slot still unknown; `—` = KASLR off, no randomization to defeat.\n'

  # The matrix reports the guaranteed window; the speculative-narrowing table
  # discloses where the likely best-guess window beats it, and by what signal.
  printf '\n'
  cmd_spec_table
}

# ---- dispatch ----
arches=$(echo "$TABLE" | awk -F'|' 'NF>1{gsub(/ /,"",$1); print $1}')

case "${1:-}" in
  table | --table)           cmd_table; exit $? ;;
  spec-table | --spec-table) cmd_spec_table; exit $? ;;
esac

sel=${1:-all}; mode=${2:-default}
[ "$sel" = all ] || mode=${2:-default}

rc=0; pass=0; fail=0; skip=0
list=$arches
[ "$sel" != all ] && list=$sel
for a in $list; do
  run_one "$a" "$mode"; st=$?
  case $st in
    0) pass=$((pass+1)) ;;
    3) skip=$((skip+1)) ;;
    *) fail=$((fail+1)); rc=1 ;;
  esac
done

echo "----------------------------------------------------------------------"
echo "vm: $pass ok, $fail fail, $skip skip  (mode=$mode)"
exit $rc
