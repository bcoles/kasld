#!/bin/sh
# This file is part of KASLD - https://github.com/bcoles/kasld
#
# replay — end-to-end smoke harness: run the real kasld binary over captured
# fixtures.
#
# For each fixture under tests/fixtures/<arch>/<host>/, reconstruct a scratch
# sysroot from its captured filesystem state and run `kasld -v` over it, then
# re-run with -H / -H -m / -H -j to sweep the hardening renderers. The check is
# that kasld RUNS to completion — parses the fixture, resolves the engine,
# renders the summary and the hardening assessment — without crashing. There is no in-process oracle to
# diff against and no stored golden master: the committed fixture is just
# sysroot/ + meta.txt + sizes.txt, and nothing depends on the volatile verbose
# output. Truth-containment and per-rule soundness are covered by the pure unit
# tests (make check / test_engine / test_engine_integration); this is the
# end-to-end "does the real binary run on real captured layouts" check.
#
# Two modes:
#   - Native (KASLD_NATIVE=1): run host-arch fixtures directly, no qemu. CI runs
#     this (x86_64 + x86_32 on an x86_64 runner); foreign-arch fixtures skip.
#   - Default: run every fixture, using qemu-user for foreign arches. Needs the
#     cross binaries from `make cross` and qemu-user in QEMU_DIR.
#
# Only a crash (death by signal) is a failure. A run yielding no results or no
# summary is informational: foreign-arch component children do not exec under
# nested qemu-user, so those fixtures legitimately produce nothing under
# emulation, and whether a leak/probe component fires is environment-dependent.
#
# Usage:  tests/replay [FIXTURE_DIR ...]      (default: all under tests/fixtures)
# Env:    QEMU_DIR      (default /home/user/qemu/build)
#         BUILD_DIR     (default ./build)
#         KASLD_NATIVE=1  run host-arch fixtures directly, no qemu (CI mode).
#                       Foreign-arch fixtures are skipped; the binary is taken
#                       from build/<arch>-*/ (any triple, gnu or musl).
#         KEEP=1        keep the scratch sysroot of the last fixture for inspection
# ---
# <bcoles@gmail.com>

set -u

ROOT=$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)
QEMU_DIR=${QEMU_DIR:-/home/user/qemu/build}
BUILD_DIR=${BUILD_DIR:-$ROOT/build}
FIXROOT=$ROOT/tests/fixtures

# Map a raw `uname -m` to "<build-subdir> <qemu-binary>". Endianness lives in
# the raw machine string (mips vs mipsel, ppc64 vs ppc64le), which is why this
# keys on uname_m_raw, not the coarser canonical arch.
target_for() {
  case "$1" in
  x86_64)            echo "x86_64-linux-musl qemu-x86_64" ;;
  i686 | i386)       echo "i686-unknown-linux-musl qemu-i386" ;;
  aarch64)           echo "aarch64-linux-musl qemu-aarch64" ;;
  armv7l | armv6l | armhf | arm)
                     echo "armv7-unknown-linux-musleabi qemu-arm" ;;
  armeb)             echo "armeb-linux-musleabi qemu-armeb" ;;
  riscv64)           echo "riscv64-linux-musl qemu-riscv64" ;;
  riscv32)           echo "riscv32-linux-musl qemu-riscv32" ;;
  mips)              echo "mips-unknown-linux-musl qemu-mips" ;;
  mipsel)            echo "mipsel-unknown-linux-musl qemu-mipsel" ;;
  mips64)            echo "mips64-unknown-linux-musl qemu-mips64" ;;
  mips64el)          echo "mips64el-unknown-linux-musl qemu-mips64el" ;;
  ppc | powerpc)     echo "powerpc-linux-musl qemu-ppc" ;;
  ppc64 | powerpc64) echo "powerpc64-unknown-linux-musl qemu-ppc64" ;;
  ppc64le | powerpc64le)
                     echo "powerpc64le-unknown-linux-musl qemu-ppc64le" ;;
  s390x)             echo "s390x-ibm-linux-musl qemu-s390x" ;;
  loongarch64)       echo "loongarch64-unknown-linux-musl qemu-loongarch64" ;;
  *)                 echo "" ;;
  esac
}

# Native (KASLD_NATIVE=1) helpers: run host-runnable fixtures with no qemu.
HOST_ARCH=$(uname -m)

# True if the host can execute fixtures of uname_m_raw $1 directly. An x86_64
# host also runs 32-bit x86; otherwise the arch must match exactly.
native_ok() {
  case "$HOST_ARCH" in
  x86_64 | amd64) case "$1" in x86_64 | i686 | i386) return 0 ;; esac ;;
  *) [ "$1" = "$HOST_ARCH" ] && return 0 ;;
  esac
  return 1
}

# Echo a build/<arch>-*/ dir holding a host-runnable kasld for uname_m_raw $1,
# or nothing. Globs the arch prefix so any triple matches (x86_64-linux-gnu from
# `make`, x86_64-linux-musl from `make cross`, i686-linux-gnu, ...).
native_bindir() {
  case "$1" in
  x86_64)    set -- "$BUILD_DIR"/x86_64-* ;;
  i686 | i386) set -- "$BUILD_DIR"/i686-* "$BUILD_DIR"/i386-* ;;
  *)         set -- "$BUILD_DIR/$1"-* ;;
  esac
  for dd in "$@"; do
    [ -x "$dd/kasld" ] && { echo "$dd"; return; }
  done
}

# Pull "key:value" out of a fixture meta.txt (collect's format).
meta() { grep -E "^$2:" "$1/meta.txt" 2>/dev/null | head -1 | sed -E 's/^[^:]*:[[:space:]]*//'; }

pass=0; fail=0; skip=0

# Fixtures are independent (each gets its own mktemp scratch sysroot), so they
# can replay JOBS at a time. The work is qemu-startup/I-O bound, not CPU bound,
# so concurrency well above the core count still pays off. KEEP=1 (inspect the
# scratch dir) forces serial so the kept path is unambiguous.
JOBS=${JOBS:-$(nproc 2>/dev/null || echo 1)}
[ "${KEEP:-0}" = 1 ] && JOBS=1

# run_fixture writes its human-readable line to stdout (the caller redirects it
# to a per-fixture .res) and a pass/fail/skip token to $st, so invocations can
# run concurrently without sharing shell state. Uses `return` (not `continue`)
# since it runs as a backgrounded function.
run_fixture() {
  d=$1 st=$2
  name=$(echo "$d" | sed "s#$FIXROOT/##")

  if [ ! -f "$d/meta.txt" ] || [ ! -f "$d/sizes.txt" ]; then
    printf 'SKIP  %-44s (no meta.txt/sizes.txt)\n' "$name"; echo skip >"$st"; return
  fi

  machine=$(meta "$d" uname_m_raw)
  release=$(meta "$d" kernel_release)

  if [ "${KASLD_NATIVE:-0}" = 1 ]; then
    # No qemu: only fixtures the host can run directly; binary from build/.
    if ! native_ok "$machine"; then
      printf 'SKIP  %-44s (native mode: non-host arch %s)\n' "$name" "$machine"; echo skip >"$st"; return
    fi
    bindir=$(native_bindir "$machine")
    if [ -z "$bindir" ]; then
      printf 'SKIP  %-44s (native mode: no host binary for %s — run make)\n' "$name" "$machine"; echo skip >"$st"; return
    fi
    kasld="$bindir/kasld"; comps="$bindir/components"; runner=""
  else
    map=$(target_for "$machine")
    if [ -z "$map" ]; then
      printf 'SKIP  %-44s (no target mapping for uname_m=%s)\n' "$name" "$machine"; echo skip >"$st"; return
    fi
    subdir=${map% *}; qbin=${map#* }
    kasld="$BUILD_DIR/$subdir/kasld"
    comps="$BUILD_DIR/$subdir/components"
    if [ ! -x "$kasld" ]; then
      printf 'SKIP  %-44s (no binary: %s — run make cross)\n' "$name" "$subdir/kasld"; echo skip >"$st"; return
    fi
    if [ ! -x "$QEMU_DIR/$qbin" ]; then
      printf 'SKIP  %-44s (no qemu: %s)\n' "$name" "$qbin"; echo skip >"$st"; return
    fi
    runner="$QEMU_DIR/$qbin"
  fi

  # Reconstruct a scratch sysroot: copy captured facts, then materialise the
  # /boot images as sparse files of their true size (header prefix preserved).
  sc=$(mktemp -d)
  cp -a "$d/sysroot" "$sc/r"
  while read -r sz path; do
    if [ -z "$sz" ] || [ -z "$path" ]; then continue; fi
    mkdir -p "$sc/r$(dirname "$path")" 2>/dev/null
    truncate -s "$sz" "$sc/r$path" 2>/dev/null
  done < "$d/sizes.txt"

  # Release handling: QEMU_UNAME sets the top-level process's uname, but is
  # NOT honored after qemu's self-re-exec for foreign-arch component children
  # — so KASLD_UNAME_RELEASE (read by kasld_uname(), propagated via the
  # environment) is what actually gives every process the fixture's release
  # for /boot path construction. Both are set; the latter is the load-bearing
  # one.
  #
  # KASLD_EXEC_WRAPPER lets the orchestrator's component children execve
  # through the host-arch qemu wrapper instead of trying to execve a guest-
  # arch ELF directly (which the host kernel refuses with ENOEXEC unless
  # binfmt_misc is registered). When $runner is non-empty (foreign-arch
  # fixture) we point KASLD_EXEC_WRAPPER at it; for native-arch fixtures
  # $runner is empty and KASLD_EXEC_WRAPPER stays unset, so the orchestrator
  # takes the production direct-execve path.
  QEMU_UNAME="$release" KASLD_UNAME_RELEASE="$release" KASLD_SYSROOT="$sc/r" \
    KASLD_COMPONENT_DIR="$comps" KASLD_EXEC_WRAPPER="$runner" \
    $runner "$kasld" -v > "$sc/replay.txt" 2>/dev/null
  rc=$?

  # Smoke verdict: the run must complete without an emulation crash. kasld
  # exits 0 with results, 1 with no tagged results (a valid empty run);
  # anything killed by a signal exits >= 128. A crash on any arch's calling
  # convention is the failure this harness exists to catch.
  #
  # With KASLD_EXEC_WRAPPER pointed at the host qemu binary, foreign-arch
  # component children do exec successfully under nested qemu-user — so
  # both x86 (native) and foreign-arch fixtures should produce results and
  # render a summary.
  has_summary=$(grep -cE '^(========|  KASLR analysis:|Virtual memory layout)' \
    "$sc/replay.txt" 2>/dev/null || true)
  n_results=$(grep -cE '^[VPD] ' "$sc/replay.txt" 2>/dev/null || true)

  # Hardening sweep: re-run with -H (text), -H -m (markdown) and -H -j (json).
  # All three render the assessment through the shared build_hardening_report()
  # model, so this is the only per-arch, real-fixture coverage of those paths —
  # it catches an emulation crash (signal) or a relocation/codegen artifact that
  # the host-only renderer unit tests cannot. Each must finish without a signal
  # (rc < 128) and emit its hardening section header. Skipped if the main run
  # already crashed.
  hard_fail=""
  if [ "$rc" -lt 128 ]; then
    for hflags in "-H" "-H -m" "-H -j"; do
      QEMU_UNAME="$release" KASLD_UNAME_RELEASE="$release" KASLD_SYSROOT="$sc/r" \
        KASLD_COMPONENT_DIR="$comps" KASLD_EXEC_WRAPPER="$runner" \
        $runner "$kasld" $hflags > "$sc/hard.txt" 2>/dev/null
      hrc=$?
      if [ "$hrc" -ge 128 ]; then
        hard_fail="$hflags signal $((hrc - 128))"
        break
      fi
      if ! grep -qE 'Hardening Assessment|"hardening"' "$sc/hard.txt"; then
        hard_fail="$hflags no hardening section"
        break
      fi
    done
  fi

  if [ "$rc" -ge 128 ]; then
    printf 'FAIL  %-44s (crashed under emulation: signal %d)\n' \
      "$name" "$((rc - 128))"
    echo fail >"$st"
  elif [ -n "$hard_fail" ]; then
    printf 'FAIL  %-44s (hardening sweep: %s)\n' "$name" "$hard_fail"
    echo fail >"$st"
  elif [ "$has_summary" -gt 0 ]; then
    printf 'PASS  %-44s rc=%d, %d results, summary + hardening rendered\n' \
      "$name" "$rc" "$n_results"
    echo pass >"$st"
  else
    printf 'PASS  %-44s rc=%d, no results, hardening rendered\n' "$name" "$rc"
    echo pass >"$st"
  fi

  if [ "${KEEP:-0}" = 1 ]; then echo "      kept scratch sysroot: $sc"; else rm -rf "$sc"; fi
}

# Launch up to JOBS fixtures concurrently, keyed by a launch index so the
# summary prints in a stable order regardless of finish order. Barrier every
# JOBS launches (POSIX sh has no `wait -n`).
RESDIR=$(mktemp -d)
n=0; running=0
for fx in "${@:-$FIXROOT/*/*}"; do
  # Expand the default glob; skip non-dirs.
  for d in $fx; do
    [ -d "$d" ] || continue
    n=$((n + 1))
    run_fixture "$d" "$RESDIR/$n.st" >"$RESDIR/$n.res" 2>&1 &
    running=$((running + 1))
    if [ "$running" -ge "$JOBS" ]; then wait; running=0; fi
  done
done
wait

# Aggregate in launch order; a missing token (job died) counts as a failure.
i=1
while [ "$i" -le "$n" ]; do
  [ -f "$RESDIR/$i.res" ] && cat "$RESDIR/$i.res"
  case $(cat "$RESDIR/$i.st" 2>/dev/null) in
    pass) pass=$((pass + 1)) ;;
    skip) skip=$((skip + 1)) ;;
    *)    fail=$((fail + 1)) ;;
  esac
  i=$((i + 1))
done
rm -rf "$RESDIR"

echo "----------------------------------------------------------------------"
printf 'replay: %d pass, %d fail, %d skip (JOBS=%s)\n' "$pass" "$fail" "$skip" "$JOBS"
[ "$fail" -eq 0 ]
