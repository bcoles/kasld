#!/bin/sh
# This file is part of KASLD - https://github.com/bcoles/kasld
#
# check-component-output — stdout-is-the-machine-channel gate.
#
# The standard (see CONTRIBUTING): a component's stdout is the MACHINE channel —
# only the P/V/S wire lines emitted by the kasld_result_* / kasld_emit_scalar
# helpers. Human diagnostics go to STDERR via the kasld_info / kasld_err /
# kasld_found / kasld_debug helpers in include/kasld/cli.h.
#
# The wire helpers never use a bare printf, so a \bprintf( in a component .c is
# always a human diagnostic on the machine channel. This check FAILS if any
# component contains one.
# ---
# <bcoles@gmail.com>

set -u
ROOT=$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)
COMP="$ROOT/src/components"

if [ -t 2 ]; then
  RED=$(printf '\033[31m'); GREEN=$(printf '\033[32m'); RESET=$(printf '\033[0m')
else
  RED=; GREEN=; RESET=
fi

offenders=$(cd "$COMP" && grep -lE '\bprintf\(' ./*.c 2>/dev/null | sed 's#^\./##' | sort -u)

if [ -n "$offenders" ]; then
  printf '%scheck-component-output: FAIL%s — stdout diagnostics; route them to\n' "$RED" "$RESET" >&2
  echo "  stderr via kasld_info / kasld_err / kasld_found (include/kasld/cli.h):" >&2
  for f in $offenders; do echo "    $f" >&2; done
  exit 1
fi

set -- "$COMP"/*.c
printf '%scheck-component-output: OK%s (%s components, stdout is wire-only)\n' \
  "$GREEN" "$RESET" "$#"
exit 0
