#!/bin/sh
# This file is part of KASLD - https://github.com/bcoles/kasld
#
# test-cross — run the engine per-rule + integration tests under qemu-user for
# each cross target, so ARCH-GATED rules actually execute their active path.
#
# `make test` runs the suite on the host (x86_64) only, where every
# `#if defined(__aarch64__)` / riscv64 / s390 / mips / ppc rule body compiles to
# a no-op — so those rules' real logic is never exercised. The engine tests are
# pure, syscall-free C over synthetic in-memory evidence (addresses anchored to
# the arch's quantity tops / PHYS_OFFSET, so portable across 64-bit arches), so
# cross-compiling and running under qemu-user is sound and turns each arch-gated
# assertion into genuine coverage on its own architecture.
#
# Self-contained: compiles directly with the cross toolchain (engine core +
# rules/*.c wildcard, matching the Makefile) — no sysroot/fixtures needed.
# Skips any target whose toolchain or qemu binary is absent. Like tests/replay,
# this is a local/CI-with-qemu aid, not part of the host `make test`.
# Exit status is non-zero if any present target fails (CI-friendly).
#
# Usage:  tests/test-cross [triple...]   (default: the local cross set; CI passes
#         one triple per matrix job)
# Env:    QEMU_DIR (default: resolve qemu-<arch> from PATH), CFLAGS, KEEP=1
# ---
# <bcoles@gmail.com>

set -u
ROOT=$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)
QEMU_DIR=${QEMU_DIR:-}   # empty: resolve qemu-<arch> from PATH
OUT=$ROOT/build/tests

# qemu-user binary for $1: from QEMU_DIR if set, else PATH. Empty if not found.
resolve_qemu() {
  if [ -n "$QEMU_DIR" ]; then
    [ -x "$QEMU_DIR/$1" ] && echo "$QEMU_DIR/$1"
  else
    command -v "$1" 2>/dev/null
  fi
}
# -Werror on the overflow/shift classes: these only manifest on a given word
# size, so the cross (esp. 32-bit) compile is where a `1ul << 40` shift or a
# constant overflow gets caught. Kept targeted (not full -Werror) so the test
# TUs' pre-existing unused-static warnings don't turn fatal.
CFLAGS=${CFLAGS:--std=c99 -O2 -static -I$ROOT/src -Werror=shift-count-overflow -Werror=overflow}
# Targets are independent (separate build dir + binaries each), so build/run
# them JOBS at a time. Default to one per core; JOBS=1 restores serial order.
JOBS=${JOBS:-$(nproc 2>/dev/null || echo 1)}
mkdir -p "$OUT"

CORE="$ROOT/src/estimate.c $ROOT/src/quantities.c $ROOT/src/evidence.c $ROOT/src/engine.c"
RULES=$(echo "$ROOT"/src/rules/*.c)

pass=0; fail=0; skip=0

# run_target writes its human-readable line(s) to stdout (the caller redirects
# this to a per-target .res file) and a single pass/fail/skip token to its .st
# file, so invocations can run concurrently without sharing shell state.
run_target() {
  triple=$1 qbin=$2
  cc="${triple}-gcc"; qemu=$(resolve_qemu "$qbin")
  st="$OUT/$triple.st"
  if ! command -v "$cc" >/dev/null 2>&1; then
    printf 'SKIP  %-30s (no toolchain: %s)\n' "$triple" "$cc"; echo skip >"$st"; return
  fi
  if [ -z "$qemu" ]; then
    printf 'SKIP  %-30s (no qemu: %s)\n' "$triple" "$qbin"; echo skip >"$st"; return
  fi
  d="$OUT/$triple"; mkdir -p "$d"
  # Per-rule engine test (every rule via the wildcard) AND the full-registry
  # integration test, both under qemu so each arch-gated rule body executes its
  # active path on its own arch. The tests anchor addresses to the arch's
  # quantity tops / PHYS_OFFSET, so they are portable across 64-bit arches.
  # (This harness has caught real arch bugs this way: a 64-bit shift overflow
  # and PHYS_OFFSET-relative assertion errors.)
  # shellcheck disable=SC2086  # $cc/$CFLAGS/$CORE/$RULES are command + flag/file lists, split intentionally
  if ! $cc $CFLAGS "$ROOT/tests/test_engine.c" $CORE $RULES -o "$d/test_engine" 2>"$d/cc.log"; then
    printf 'FAIL  %-30s (compile test_engine)\n' "$triple"; sed 's/^/      /' "$d/cc.log" | head -5; echo fail >"$st"; return
  fi
  # shellcheck disable=SC2086  # $cc/$CFLAGS/$CORE/$RULES are command + flag/file lists, split intentionally
  if ! $cc $CFLAGS "$ROOT/tests/test_engine_integration.c" $CORE "$ROOT/src/engine_rules.c" $RULES \
        -o "$d/test_integration" 2>"$d/cc.log"; then
    printf 'FAIL  %-30s (compile test_integration)\n' "$triple"; sed 's/^/      /' "$d/cc.log" | head -5; echo fail >"$st"; return
  fi
  # The parser / result-model / merge / engine-sync unit suite (its renderer
  # half is now test_render, below). It includes the orchestrator + render
  # translation units directly (hence -DKASLD_TESTING and -lpthread) and derives
  # every fixture address from the arch's own layout constants, so it runs on
  # every width and endianness.
  # shellcheck disable=SC2086  # $cc/$CFLAGS are command + flag list, split intentionally
  if ! $cc $CFLAGS -DKASLD_TESTING "$ROOT/tests/test_kasld.c" -o "$d/test_kasld" -lpthread 2>"$d/cc.log"; then
    printf 'FAIL  %-30s (compile test_kasld)\n' "$triple"; sed 's/^/      /' "$d/cc.log" | head -5; echo fail >"$st"; return
  fi
  # The renderer unit suite (split from test_kasld); same single-TU model.
  # shellcheck disable=SC2086  # $cc/$CFLAGS are command + flag list, split intentionally
  if ! $cc $CFLAGS -DKASLD_TESTING "$ROOT/tests/test_render.c" -o "$d/test_render" -lpthread 2>"$d/cc.log"; then
    printf 'FAIL  %-30s (compile test_render)\n' "$triple"; sed 's/^/      /' "$d/cc.log" | head -5; echo fail >"$st"; return
  fi
  ok=1
  for t in test_engine test_integration test_kasld test_render; do
    if ! "$qemu" "$d/$t" >/dev/null 2>"$d/$t.run"; then
      printf 'FAIL  %-30s (%s under qemu)\n' "$triple" "$t"; tail -3 "$d/$t.run" | sed 's/^/      /'; ok=0
    fi
  done
  if [ "$ok" = 1 ]; then
    printf 'PASS  %-30s engine + integration + kasld + render\n' "$triple"; echo pass >"$st"
  else
    echo fail >"$st"
  fi
  [ "${KEEP:-0}" = 1 ] || rm -rf "$d"
}

# qemu-user binary for a toolchain triple, keyed on the leading arch component
# so both `make cross` names (aarch64-linux-musl) and the cross-tools/musl-cross
# CI names (aarch64-unknown-linux-musl) resolve. Empty for arches with no
# qemu-user binary (32-bit little-endian ppc, powerpcle) — those skip.
qemu_for() {
  case "${1%%-*}" in
  x86_64)      echo qemu-x86_64 ;;
  i686 | i586) echo qemu-i386 ;;
  aarch64)     echo qemu-aarch64 ;;
  arm | armv7) echo qemu-arm ;;
  armeb)       echo qemu-armeb ;;
  mips)        echo qemu-mips ;;
  mipsel)      echo qemu-mipsel ;;
  mips64)      echo qemu-mips64 ;;
  mips64el)    echo qemu-mips64el ;;
  powerpc)     echo qemu-ppc ;;
  powerpc64)   echo qemu-ppc64 ;;
  powerpc64le) echo qemu-ppc64le ;;
  riscv32)     echo qemu-riscv32 ;;
  riscv64)     echo qemu-riscv64 ;;
  s390x)       echo qemu-s390x ;;
  loongarch64) echo qemu-loongarch64 ;;
  *)           echo "" ;;
  esac
}

# Targets: toolchain triples from argv if given (CI passes one arch per matrix
# job), else the built-in local set `make cross` builds. qemu is derived per
# triple via qemu_for, so dev and CI triple spellings both work.
#
# Both 64-bit and 32-bit targets run; 64-bit-only tests (x86_64 RANDOMIZE_MEMORY
# vmalloc/vmemmap, LA57/arm64 VA-bits, TiB-scale direct maps, wide PA widths) are
# `#if __SIZEOF_LONG__ >= 8`-guarded and skip on 32-bit. This executes each
# arch-gated rule body on its own arch: i686 -> x86_32 vmsplit ceiling, armv7 ->
# arm32 highmem_32bit_bound, mips -> mips32 min_offset_from_image_size, powerpc
# -> ppc32 phys_ceiling (BE), riscv32 -> page_offset_invariant_pin +
# text_base_coupling_synth. ppc32 little-endian (powerpcle) has no 32-bit-LE
# qemu-user, so it stays live-test-only.
default_triples='aarch64-linux-musl arm-unknown-linux-musleabi
armeb-linux-musleabi armv7-unknown-linux-musleabi i686-unknown-linux-musl
mips64-unknown-linux-musl mips64el-unknown-linux-musl powerpc-linux-musl
powerpc64-unknown-linux-musl powerpc64le-unknown-linux-musl
loongarch64-unknown-linux-musl mips-unknown-linux-musl mipsel-unknown-linux-musl
riscv32-linux-musl riscv64-linux-musl s390x-ibm-linux-musl x86_64-linux-musl'

# No argv -> use the built-in set (intentional word-split into $@).
if [ "$#" -eq 0 ]; then
  # shellcheck disable=SC2086
  set -- $default_triples
fi

# Launch up to JOBS targets concurrently, each writing to its own .res/.st;
# barrier every JOBS launches (POSIX sh has no `wait -n`). Order is recorded so
# the summary prints deterministically regardless of finish order.
order=""
running=0
for triple in "$@"; do
  order="$order $triple"
  qbin=$(qemu_for "$triple")
  if [ -z "$qbin" ]; then
    printf 'SKIP  %-30s (no qemu-user binary for this arch)\n' "$triple" >"$OUT/$triple.res"
    echo skip >"$OUT/$triple.st"
    continue
  fi
  run_target "$triple" "$qbin" >"$OUT/$triple.res" 2>&1 &
  running=$((running + 1))
  if [ "$running" -ge "$JOBS" ]; then wait; running=0; fi
done
wait

# Aggregate in launch order: print each target's captured output, tally its
# status token. A missing token (a job that died before writing) counts as a
# failure rather than vanishing.
for triple in $order; do
  [ -f "$OUT/$triple.res" ] && cat "$OUT/$triple.res"
  case $(cat "$OUT/$triple.st" 2>/dev/null) in
    pass) pass=$((pass + 1)) ;;
    skip) skip=$((skip + 1)) ;;
    *)    fail=$((fail + 1)) ;;
  esac
  rm -f "$OUT/$triple.res" "$OUT/$triple.st"
done

echo "----------------------------------------------------------------------"
printf 'test-cross: %d pass, %d fail, %d skip (JOBS=%s)\n' "$pass" "$fail" "$skip" "$JOBS"
[ "$fail" -eq 0 ]
